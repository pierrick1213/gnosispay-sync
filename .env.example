# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gnosispaysync
POSTGRES_PORT=5432

# GnosisPay
GNOSISPAY_API_BASE_URL=https://api.gnosispay.com
GNOSISPAY_PRIVATE_KEY=0xCHANGE_ME_YOUR_SIGNIN_PRIVATE_KEY

# Image — override to pin a specific version, e.g. pierrick1213/gnosispay-sync:1.0.0
GNOSISPAY_SYNC_IMAGE=pierrick1213/gnosispay-sync:latest
# "always" = re-pull on every `docker compose up`, "missing" = only if not present locally, "never" = use local build
PULL_POLICY=always
