# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gnosispaysync
POSTGRES_PORT=5432

# GnosisPay
GNOSISPAY_API_BASE_URL=https://api.gnosispay.com
GNOSISPAY_PRIVATE_KEY=0xCHANGE_ME_YOUR_SIGNIN_PRIVATE_KEY

# Image — override to pin a specific version, e.g. pickcool/gnosispay-sync:1.0.0
GNOSISPAY_SYNC_IMAGE=pickcool/gnosispay-sync:latest
